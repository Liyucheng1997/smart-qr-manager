# 生产环境变量示例（部署脚本会自动生成 /etc/smart-qr.env）
NODE_ENV=production
PORT=3000
# 用随机字符串，例如： node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=请替换为一个随机密钥
# 网站对外地址（务必与实际域名一致，二维码会编码该地址）
BASE_URL=https://your-domain.com
# 数据存放目录（持久化磁盘路径）
DATA_DIR=/home/ubuntu/smart-qr-manager/data
# 管理员邮箱（可填多个，逗号分隔）。用这些邮箱注册/登录后可访问 /admin.html 后台
ADMIN_EMAILS=liyucheng97@126.com
# ---- 会员/支付 ----
# 会员价格（元），默认 9.90
MEMBERSHIP_PRICE=9.90
# 手动模式（默认）：把你的收款码图片放到 public/pay-wechat.png 和 public/pay-alipay.png，
#   用户扫码付款 → 点“我已支付” → 你在 /admin.html 点“设为会员”确认。无需下面的虎皮椒配置。
# 自动模式（可选，需到 https://www.xunhupay.com 开通，要费用）：填下面两项即切换为扫码自动到账。
XUNHU_APPID=
XUNHU_APPSECRET=
