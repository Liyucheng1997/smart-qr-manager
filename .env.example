# 生产环境变量示例（部署脚本会自动生成 /etc/smart-qr.env）
NODE_ENV=production
PORT=3000
# 用随机字符串，例如： node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=请替换为一个随机密钥
# 网站对外地址（务必与实际域名一致，二维码会编码该地址）
BASE_URL=https://your-domain.com
# 数据存放目录（持久化磁盘路径）
DATA_DIR=/home/ubuntu/smart-qr-manager/data
# 管理员邮箱（可填多个，逗号分隔）。用这些邮箱注册/登录后可访问 /admin.html 后台
ADMIN_EMAILS=liyucheng97@126.com
